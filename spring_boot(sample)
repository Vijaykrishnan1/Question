@Service
public class PasswordResetService {

    @Autowired
    private UserRepository userRepo;

    @Autowired
    private OtpRepository otpRepo;

    public String generateOtp(String email) {
        String otp = String.valueOf(new Random().nextInt(999999));
        OtpEntity entity = new OtpEntity(email, otp, LocalDateTime.now().plusMinutes(5));
        otpRepo.save(entity);
        return otp;
    }

    public boolean resetPassword(String email, String otp, String newPassword) {
        OtpEntity record = otpRepo.findByEmail(email);

        if (record == null || !record.getOtp().equals(otp)) {
            throw new RuntimeException("Invalid OTP");
        }

        if (record.getExpiry().isBefore(LocalDateTime.now())) {
            throw new RuntimeException("OTP Expired");
        }

        User user = userRepo.findByEmail(email);
        user.setPassword(new BCryptPasswordEncoder().encode(newPassword));
        userRepo.save(user);

        otpRepo.delete(record);
        return true;
    }
}
